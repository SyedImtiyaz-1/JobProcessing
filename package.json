{
  "name": "job-processing-api",
  "version": "1.0.0",
  "description": "Scalable background job processing API with priority queue, rate limiting, SSE, and observability",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/server.js",
    "dev": "node --watch --env-file-if-exists=.env src/server.js",
    "seed": "node scripts/seed.js",
    "test": "node --test --env-file-if-exists=.env.test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.1"
  }
}
